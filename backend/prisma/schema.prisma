generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Placeholder model to validate Prisma setup before product tables are designed.
model SystemEvent {
  id        String   @id @default(cuid())
  name      String
  metadata  Json?
  createdAt DateTime @default(now())
}
